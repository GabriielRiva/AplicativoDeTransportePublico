{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "drivers": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "lines": {
      ".read": "auth != null",
      ".write": false
    },
    "stops": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["lineId"]
    },
    "schedules": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["lineId"]
    },
    "buses": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["lineId"]
    }
  }
}
